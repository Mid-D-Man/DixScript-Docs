@CONFIG(
  version  -> "1.0.0"
  author   -> "Cloud Cyclic Detection — File B (imports cloud A which imports cloud B)"
  features -> "advanced"
)

@IMPORTS(
  A from_cloud "https://dixscript-docs.pages.dev/api/registry/circular_cloud_a.mdix"
)

@DATA(
  source  = "circular_cloud_b"
  note    = "This file and circular_cloud_a form a cycle — compiler must detect it"
)
